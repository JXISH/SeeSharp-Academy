<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HWAIGuideGenerator.ViewModels"
        x:Class="HWAIGuideGenerator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="硬件AI训导词生成器 - HW AI Guide Generator"
        Width="900"
        Height="850"
        MinWidth="800"
        MinHeight="700">
    
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto">
        
        <!-- 输入区域 -->
        <Border Grid.Row="0" 
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12">
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="120,150,16,100,*,8,70">
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="输入设置" 
                           FontWeight="SemiBold" 
                           FontSize="16"
                           Grid.ColumnSpan="7"
                           Margin="0,0,0,12"/>
                
                <!-- JYPEDIA文件路径 -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="JYPEDIA文件:" 
                           VerticalAlignment="Center"/>
                <AutoCompleteBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4"
                                 Text="{Binding JypediaFilePath, Mode=TwoWay}"
                                 ItemsSource="{Binding JypediaFilePathHistory}"
                                 FilterMode="Contains"
                                 Margin="8,0,0,0"/>
                <Button Grid.Row="1" Grid.Column="6" 
                        Content="浏览..."
                        Command="{Binding BrowseJypediaFileCommand}"/>
                
                <!-- 操作系统和硬件型号 -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="操作系统:" 
                           VerticalAlignment="Center"
                           Margin="0,12,0,0"/>
                <ComboBox Grid.Row="2" Grid.Column="1" 
                          ItemsSource="{Binding OperatingSystemOptions}"
                          SelectedItem="{Binding SelectedOperatingSystem}"
                          Margin="8,12,0,0"/>
                
                <TextBlock Grid.Row="2" Grid.Column="3" 
                           Text="硬件型号:" 
                           VerticalAlignment="Center"
                           Margin="0,12,0,0"/>
                <AutoCompleteBox Grid.Row="2" Grid.Column="4" 
                                 Text="{Binding HardwareModel, Mode=TwoWay}"
                                 ItemsSource="{Binding HardwareModelHistory}"
                                 FilterMode="Contains"
                                 Margin="8,12,0,0"/>
                <Button Grid.Row="2" Grid.Column="6" 
                        Content="查找"
                        Command="{Binding SearchCommand}"
                        IsEnabled="{Binding !IsProcessing}"
                        Margin="0,12,0,0"
                        Classes="accent"/>
            </Grid>
        </Border>
        
        <!-- 复制驱动选项 -->
        <Border Grid.Row="1" 
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12">
            <StackPanel Spacing="8">
                <CheckBox Content="复制驱动到目标目录" 
                          IsChecked="{Binding CopyDriver}"/>
                
                <Grid ColumnDefinitions="120,*,Auto" 
                      IsVisible="{Binding CopyDriver}">
                    <TextBlock Grid.Column="0" 
                               Text="驱动目标目录:" 
                               VerticalAlignment="Center"/>
                    <AutoCompleteBox Grid.Column="1" 
                                     Text="{Binding TargetDriverDirectory, Mode=TwoWay}"
                                     ItemsSource="{Binding DriverDirectoryHistory}"
                                     FilterMode="Contains"
                                     Margin="8,0"/>
                    <Button Grid.Column="2" 
                            Content="浏览..."
                            Command="{Binding BrowseDriverDirectoryCommand}"
                            MinWidth="70"/>
                </Grid>
            </StackPanel>
        </Border>
        
        <!-- 主内容区域 -->
        <Grid Grid.Row="2" ColumnDefinitions="*,16,*" Margin="0,0,0,12">
            
            <!-- 左侧: 范例选择树 -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" 
                               Text="范例选择" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,8"/>
                    
                    <TreeView Grid.Row="1" 
                              ItemsSource="{Binding ExampleTree}"
                              IsVisible="{Binding HasExampleTree}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    
                    <TextBlock Grid.Row="1"
                               Text="{Binding ExampleStatusMessage}"
                               IsVisible="{Binding !HasExampleTree}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Grid>
            </Border>
            
            <!-- 右侧: 输出和历史 -->
            <Grid Grid.Column="2" RowDefinitions="*,Auto,*">
                
                <!-- 输出区域 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Row="0" 
                                   Text="输出 / AI训导词" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,8"/>
                        
                        <TextBox Grid.Row="1"
                                 Text="{Binding OutputText}"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"/>
                        
                        <!-- 按钮区域: 生成AI训导词 + 复制到剪贴板 -->
                        <Grid Grid.Row="2" ColumnDefinitions="*,12,*" Margin="0,10,0,0">
                            <Button Grid.Column="0"
                                    Content="生成AI训导词"
                                    Command="{Binding GenerateCommand}"
                                    IsEnabled="{Binding HasSearchResult}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Classes="accent"/>
                            <Button Grid.Column="2"
                                    Content="复制到剪贴板"
                                    Command="{Binding CopyToClipboardCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                
                <GridSplitter Grid.Row="1" 
                              Height="8"
                              Background="Transparent"/>
                
                <!-- 历史记录 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" 
                                   Text="历史记录" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,8"/>
                        
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding OutputHistory}"
                                 SelectedItem="{Binding SelectedOutputHistory}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayTitle}" 
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- 状态栏 -->
        <Border Grid.Row="3"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="4"
                Padding="12,6">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="12"/>
        </Border>
        
    </Grid>
</Window>
